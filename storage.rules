rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── User Avatars ──────────────────────────────────────────────────────
    // Any authenticated user can view avatars (needed for group member lists).
    // Users can only upload/replace their own avatar.
    // Max 5 MB, images only.
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Group Cover Photos ────────────────────────────────────────────────
    // Any authenticated user can view (simplification — group membership
    // is enforced at the Firestore level for the group document itself).
    // Max 5 MB, images only.
    match /groups/{groupId}/cover/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Expense Receipts ──────────────────────────────────────────────────
    // Any authenticated user can view receipts (group membership enforced
    // at the Firestore level).
    // Max 10 MB, images only.
    match /groups/{groupId}/receipts/{expenseId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Friend Expense Receipts ───────────────────────────────────────────
    // Max 10 MB, images only.
    match /friends/{friendPairId}/receipts/{expenseId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ── Deny all other paths ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
